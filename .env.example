# ============================================
# Configuracion de Base de Datos (PostgreSQL)
# ============================================
# IMPORTANTE: Para Render, configura esta variable en el Dashboard
# Obten la URL desde Render Dashboard > Environment Variables
# Ejemplo:
# DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db?schema=academic
DATABASE_URL=

# ============================================
# Puerto del servidor (Render lo asigna automaticamente)
# ============================================
PORT=3000

# ============================================
# Entorno de ejecucion
# ============================================
NODE_ENV=development

